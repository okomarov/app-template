{
  "permissions": {
    "allow": [
      "Bash(npx tsc:*)",
      "Bash(npx biome:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run build:*)",
      "Bash(npm run test:*)",
      "Bash(npm run check:*)",
      "Bash(npx vitest:*)",
      "Bash(npm run db:types:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(supabase gen types:*)",
      "Bash(supabase db diff:*)",
      "Bash(supabase status:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|mcp__supabase__execute_sql|mcp__plugin_supabase_supabase__execute_sql",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/guard-prod.sh",
            "timeout": 5,
            "statusMessage": "Checking for prod write operations..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/quiet.sh npx biome check --fix --unsafe $CLAUDE_FILE_PATHS",
            "timeout": 10,
            "statusMessage": "Auto-formatting..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/quiet.sh sh -c 'npx tsc --noEmit && npx biome check . && npx vitest run --project unit --passWithNoTests'",
            "timeout": 60,
            "statusMessage": "Verifying types, lint, and unit tests..."
          }
        ]
      }
    ]
  }
}
