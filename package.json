{
  "name": "app-template",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "postinstall": "next telemetry disable >/dev/null 2>&1 || true",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "check": "tsc --noEmit && biome check .",
    "db:new": "supabase migration new",
    "db:push:local": "supabase db push --local",
    "db:push:staging": "source .env.local && supabase db push --db-url $DATABASE_URL",
    "db:push:prod": "source .env.production && supabase db push --db-url $DATABASE_URL",
    "db:types": "source .env.local && supabase gen types typescript --project-id $SUPABASE_PROJECT_ID --schema $DB_SCHEMA > src/db/types.ts",
    "db:types:local": "source .env.local && supabase gen types typescript --local --schema $DB_SCHEMA > src/db/types.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.39.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-query": "^5.66.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "dayjs": "^1.11.20",
    "kysely": "^0.28.0",
    "kysely-postgres-js": "^3.0.0",
    "lucide-react": "^0.577.0",
    "next": "^16.2.3",
    "postgres": "^3.4.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
